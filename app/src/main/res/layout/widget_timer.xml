<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_beer"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="5dp"
    android:paddingTop="2dp"
    android:paddingEnd="5dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="15dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widgetLogo"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_hops_vr2" />

        <TextView
            android:id="@+id/widgetBeerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:fontFamily="sans-serif-medium"
            android:text="Beer"
            android:textColor="#4A2509"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widgetChillerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="CHILLER"
            android:textColor="#D99C00"
            android:textSize="11sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/widgetRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:contentDescription="@string/remaining_time"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/widgetIdleMug"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_beer_mug_button"
            android:visibility="gone" />

        <Chronometer
            android:id="@+id/widgetCountdown"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:countDown="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#4A2509"
            android:textSize="23sp" />

        <TextView
            android:id="@+id/widgetIdleTime"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="--:--"
            android:textColor="#4A2509"
            android:textSize="23sp" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/widgetBottomRow"
        android:layout_width="match_parent"
        android:layout_height="13dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widgetTemperatureIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/current_temperature_short"
            android:src="@drawable/ic_temp_vr2" />

        <TextView
            android:id="@+id/widgetTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.52"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:maxLines="1"
            android:text="8 °C"
            android:textColor="#4A2509"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/widgetEndTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.48"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:gravity="end|center_vertical"
            android:maxLines="1"
            android:text="--:--"
            android:textColor="#4A2509"
            android:textSize="8sp" />
    </LinearLayout>
</LinearLayout>
