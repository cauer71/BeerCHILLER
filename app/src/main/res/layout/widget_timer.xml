<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_beer"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="4dp"
    android:paddingEnd="10dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widgetLogo"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_hops_vr2" />

        <TextView
            android:id="@+id/widgetBeerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:fontFamily="sans-serif-medium"
            android:text="Beer"
            android:textColor="#4A2509"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widgetChillerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="CHILLER"
            android:textColor="#D99C00"
            android:textSize="13sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="166dp"
        android:layout_height="166dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp">

        <ImageView
            android:id="@+id/widgetRing"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:contentDescription="@string/remaining_time"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/widgetIdleMug"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_beer_mug_button"
            android:visibility="gone" />

        <Chronometer
            android:id="@+id/widgetCountdown"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:countDown="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#4A2509"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/widgetIdleTime"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:maxLines="1"
            android:text="--:--"
            android:textColor="#4A2509"
            android:textSize="28sp" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/widgetBottomRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widgetTemperatureIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="@string/current_temperature_short"
            android:src="@drawable/ic_temp_vr2" />

        <TextView
            android:id="@+id/widgetTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:gravity="start|center_vertical"
            android:maxLines="1"
            android:text="8 °C"
            android:textColor="#4A2509"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widgetEndTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:gravity="end|center_vertical"
            android:maxLines="1"
            android:text="--:--"
            android:textColor="#4A2509"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
