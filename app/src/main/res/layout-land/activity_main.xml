<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFA">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        android:src="@drawable/beer_background"
        android:visibility="gone" />

    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_beer_overlay"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="16dp"
        android:paddingRight="24dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/headerTitleGroup"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginRight="8dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_snowflake" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bier"
                android:textColor="#E8B923"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHILLER"
                android:textColor="#123B4A"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="18dp"
                android:layout_weight="0.76"
                android:padding="2dp">

                <com.example.helloworld.TimerCircleView
                    android:id="@+id/timerCircle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.04"
                android:orientation="vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_control_panel"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:paddingLeft="34dp"
                    android:paddingTop="12dp"
                    android:paddingRight="34dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/volumeSmallButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_unselected"
                            android:elevation="3dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="0,33 l"
                            android:textAllCaps="false"
                            android:textColor="#123B4A"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/volumeMediumButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_selected"
                            android:elevation="3dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="0,5 l"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/volumeLargeButton"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_unselected"
                            android:elevation="3dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="1,0 l"
                            android:textAllCaps="false"
                            android:textColor="#123B4A"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <include layout="@layout/temperature_row_start" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#DCEAE8" />

                        <include layout="@layout/temperature_row_target" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#DCEAE8" />

                        <include layout="@layout/temperature_row_device" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/startButton"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_button"
                        android:clickable="true"
                        android:elevation="4dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/startButtonIcon"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_marginRight="8dp"
                            android:contentDescription="@string/start_timer"
                            android:src="@drawable/ic_beer_mug_button" />

                        <TextView
                            android:id="@+id/startButtonText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/start_timer"
                            android:textColor="#102A33"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/stopButton"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_secondary_button"
                        android:elevation="2dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/stop_timer"
                        android:textAllCaps="false"
                        android:textColor="#123B4A"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
