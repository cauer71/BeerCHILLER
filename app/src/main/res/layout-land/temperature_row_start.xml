<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="42dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/startTempIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginRight="8dp"
        android:src="@drawable/ic_temp_vr2"
        android:visibility="gone" />

    <TextView
        android:id="@+id/startTempLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:autoSizeMaxTextSize="12sp"
        android:autoSizeMinTextSize="7sp"
        android:autoSizeStepGranularity="1sp"
        android:autoSizeTextType="uniform"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:paddingRight="10dp"
        android:text="@string/start_temperature"
        android:textColor="#123B4A"
        android:textSize="12sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/startMinusButton"
        android:layout_width="33dp"
        android:layout_height="33dp"
        android:background="@drawable/bg_step_button"
        android:elevation="5dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="-"
        android:textColor="#123B4A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/startTempValue"
        android:layout_width="78dp"
        android:layout_height="33dp"
        android:layout_marginLeft="7dp"
        android:layout_marginRight="7dp"
        android:background="@drawable/bg_value_chip"
        android:elevation="2dp"
        android:gravity="center"
        android:text="22 &#176;C"
        android:textColor="#123B4A"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/startPlusButton"
        android:layout_width="33dp"
        android:layout_height="33dp"
        android:background="@drawable/bg_step_button"
        android:elevation="5dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="+"
        android:textColor="#123B4A"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
