<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/deviceTempIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginRight="14dp"
        android:src="@drawable/ic_snowflake_material_vr2" />

    <TextView
        android:id="@+id/deviceTempLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:paddingRight="18dp"
        android:text="@string/device_temperature"
        android:textColor="#123B4A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/deviceMinusButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_step_button"
        android:elevation="5dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="-"
        android:textColor="#123B4A"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/deviceTempValue"
        android:layout_width="112dp"
        android:layout_height="42dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/bg_value_chip"
        android:elevation="2dp"
        android:gravity="center"
        android:text="-18 &#176;C"
        android:textColor="#123B4A"
        android:textSize="19sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/devicePlusButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_step_button"
        android:elevation="5dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="+"
        android:textColor="#123B4A"
        android:textSize="24sp"
        android:textStyle="bold" />
</LinearLayout>
