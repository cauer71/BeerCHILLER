<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFA"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/app_name"
        android:scaleType="centerCrop"
        android:src="@drawable/beer_background"
        android:visibility="gone" />

    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_beer_overlay"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingTop="18dp"
        android:paddingRight="32dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/headerTitleGroup"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/headerLogoIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginRight="10dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_snowflake" />

            <TextView
                android:id="@+id/headerBeerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bier"
                android:textColor="#E8B923"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headerChillerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHILLER"
                android:textColor="#123B4A"
                android:textSize="32sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/menuButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu_open"
                android:padding="12dp"
                android:src="@drawable/ic_more_vert" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="34dp"
                android:layout_weight="0.92"
                android:padding="0dp">

                <com.bierchiller.app.TimerCircleView
                    android:id="@+id/timerCircle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.08"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp">

                <LinearLayout
                    android:id="@+id/controlPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_control_panel"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:elevation="4dp"
                    android:orientation="vertical"
                    android:paddingLeft="38dp"
                    android:paddingTop="20dp"
                    android:paddingRight="38dp"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:id="@+id/selectionTopRow"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginBottom="8dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/containerTypeGroup"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_group"
                            android:clipToPadding="false"
                            android:elevation="2dp"
                            android:orientation="horizontal"
                            android:padding="3dp">

                            <Button
                                android:id="@+id/bottleButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_selected"
                                android:elevation="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:text="@string/container_bottle"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/canButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_unselected"
                                android:elevation="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:text="@string/container_can"
                                android:textAllCaps="false"
                                android:textColor="#123B4A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/orientationGroup"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_group"
                            android:clipToPadding="false"
                            android:elevation="2dp"
                            android:orientation="horizontal"
                            android:padding="3dp">

                            <Button
                                android:id="@+id/lyingButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_selected"
                                android:elevation="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:text="@string/orientation_lying"
                                android:textAllCaps="false"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/standingButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@drawable/bg_segment_unselected"
                                android:elevation="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:text="@string/orientation_standing"
                                android:textAllCaps="false"
                                android:textColor="#123B4A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/volumeRow"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_segment_group"
                        android:clipToPadding="false"
                        android:elevation="2dp"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <Button
                            android:id="@+id/volumeSmallButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_unselected"
                            android:elevation="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="0,33 l"
                            android:textAllCaps="false"
                            android:textColor="#123B4A"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/volumeMediumButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_selected"
                            android:elevation="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="0,5 l"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/volumeLargeButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_unselected"
                            android:elevation="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="1,0 l"
                            android:textAllCaps="false"
                            android:textColor="#123B4A"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="0dp"
                        android:layout_marginBottom="14dp"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/freezerButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_selected"
                            android:elevation="3dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="@string/freezer"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/fridgeButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_segment_unselected"
                            android:elevation="3dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:text="@string/fridge"
                            android:textAllCaps="false"
                            android:textColor="#123B4A"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:orientation="vertical">

                        <include layout="@layout/temperature_row_start" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#DCEAE8" />

                        <include layout="@layout/temperature_row_target" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#DCEAE8" />

                        <include layout="@layout/temperature_row_device" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/bottomButtonRow"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/startButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_button"
                        android:clickable="true"
                        android:elevation="4dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/startButtonIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginRight="10dp"
                            android:contentDescription="@string/start_timer"
                            android:src="@drawable/ic_beer_mug_button" />

                        <TextView
                            android:id="@+id/startButtonText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/start_timer"
                            android:textColor="#102A33"
                            android:textSize="19sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/stopButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_secondary_button"
                        android:elevation="2dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="@string/stop_timer"
                        android:textAllCaps="false"
                        android:textColor="#123B4A"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
